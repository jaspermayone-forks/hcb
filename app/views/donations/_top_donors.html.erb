<%# locals: (top_donors:) %>
<% unless top_donors.empty? %>
  <div class="card">
    <h2 class="mt-0">Top donors</h2>

    <div class="flex items-end justify-center gap-2 mt-4">
      <% [[1, "second", "🥈"], [0, "first", "🥇"], [2, "third", "🥉"]].each do |index, rank, medal| %>
        <% if (donor = top_donors[index]) %>
          <div class="flex flex-col items-center flex-1 min-w-0">
            <div class="podium-block podium-block--<%= rank %>">
              <h3 class="mt-0 mb-1"><%= medal %></h3>
              <p class="text-lg font-semibold text-center my-0 leading-tight truncate w-full px-1"><%= donor.name %></p>
              <p class="text-xs text-center opacity-50 mt-1 mb-0"><%= render_money(donor.amount) %></p>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>

    <% top_donors[3..]&.each_with_index do |donor, i| %>
      <div class="card shadow-none bg-gray-100 mt-2 flex items-center gap-3 py-2">
        <span class="text-xs text-gray-400 font-bold w-5 text-center shrink-0">#<%= i + 4 %></span>
        <span class="text-sm font-medium truncate"><%= donor.name %></span>
        <span class="text-sm ml-auto shrink-0"><%= render_money(donor.amount) %></span>
      </div>
    <% end %>
  </div>
<% end %>
