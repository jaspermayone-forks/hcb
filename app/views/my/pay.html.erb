<% title "Pay" %>
<% page_md %>
<%= render "users/nav", selected: :pay %>

<h1 class="heading flex-col sm:flex-row border-0 mb-0">
  <div class="flex flex-row items-baseline gap-5 flex-wrap">
    <span>
      Pay
    </span>

    <% if @legal_entities.many? %>
      <div data-controller="menu" data-menu-placement-value="bottom-start" class="inline-block">
        <div class="text-white text-base flex items-center -mt-1 gap-0.5 opacity-75 font-[500] cursor-pointer"
                data-menu-target="toggle"
                data-action="click->menu#toggle click@document->menu#close keydown@document->menu#keydown">
          <%= @legal_entity.display_name %>
          <%= inline_icon "down-caret", size: 20 %>
                </div>
        <div class="menu__content menu__content--2 h5 menu__content--compact" data-menu-target="content">
          <% @legal_entities.each do |le| %>
            <%= link_to my_pay_path(legal_entity_id: le.id), class: "flex items-center#{" bold" if le == @legal_entity}" do %>
              <%= inline_icon(le.person? ? "person" : "bank-account", size: 24) %>
              <%= le.display_name %>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
  <div class="flex sm:ml-auto gap-2 items-center flex-wrap justify-center">
    <% if @payout_method.present? %>
      <%= link_to settings_payouts_path(legal_entity_id: @legal_entity.id), class: "!ml-0 btn bg-info" do %>
        <%= inline_icon @payout_method.icon %>
        Payout settings
      <% end %>
    <% else %>
      <%= link_to settings_payouts_path(legal_entity_id: @legal_entity.id), class: "!ml-0 btn" do %>
        <%= inline_icon "bank-account" %>
        Configure payouts
      <% end %>
    <% end %>
  </div>
</h1>

<%= render "application/flash", klass: "max-w-full mb3" %>

<div class="statset mb-4">
  <div class="stat">
    <span class="stat__label">Total</span>
    <span class="stat__value"><%= render_money_amount @stats[:deposited] %></span>
  </div>
  <div class="stat stat--small">
    <span class="stat__label">On the way</span>
    <span class="stat__value"><%= render_money_amount @stats[:in_transit] %></span>
  </div>
  <div class="stat stat--small">
    <span class="stat__label">Canceled</span>
    <span class="stat__value"><%= render_money_amount @stats[:canceled] %></span>
  </div>
</div>

<% if @contractor_positions.any? %>
  <% if @tax_form_required %>
    <div class="card border b--warning warning flex items-center justify-between gap-4 p-4 mb-4">
      <span class="flex items-center gap-2">
        <%= inline_icon "important", size: 32, class: "shrink-0" %>
        <span>
          <strong>Action required:</strong>
          You haven't submitted your tax information yet. HCB requires this before releasing any payments.
        </span>
      </span>
      <%= link_to tax_forms_path, params: { legal_entity_id: @legal_entity.hashid }, class: "bold nowrap flex items-center gap-1" do %>
        Complete tax form
        <%= inline_icon "view-forward" %>
      <% end %>
    </div>
  <% end %>

  <h2 class="mt-0 mb-2">Your contracts</h2>
  <article class="table-container mb-4">
    <table>
      <thead>
        <tr>
          <th>Status</th>
          <th>Organization</th>
          <th>Period</th>
          <th>Rate</th>
          <th>Purpose</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @contractor_positions.each do |position| %>
          <% onboarding = position.status == :onboarding %>
          <% next_step = position.next_onboarding_step if onboarding %>
          <% legal_entity = position.payee.legal_entity %>
          <tr>
            <td>
              <span class="badge ml-0 bg-<%= onboarding ? "warning" : position.status_color %>"
                    <% if next_step %> title="Next step: <%= next_step[:label] %>"<% end %>>
                <%= onboarding ? "Onboarding" : position.status_text %>
              </span>
            </td>
            <td><strong><%= position.event.name %></strong></td>
            <td><%= position.period_label %></td>
            <td><%= "#{render_money_short(position.rate_cents)}/hr" %></td>
            <td style="max-width: 25ch;" class="overflow-hidden truncate" title="<%= position.description %>">
              <%= position.description %>
            </td>
            <td class="text-right">
              <% if position.status == :active %>
                <%= link_to "#", class: "btn bg-success nowrap", data: { behavior: "modal_trigger", modal: dom_id(position, :submit_invoice) } do %>
                  <%= inline_icon "cloud-upload" %>
                  Submit invoice
                <% end %>

                <section class="modal modal--scroll bg-snow" data-behavior="modal" role="dialog"
                  id="<%= dom_id(position, :submit_invoice) %>"
                  data-controller="turbo-frame-modal"
                  data-action="turbo:submit-end->turbo-frame-modal#submitEnd">
                  <%= modal_header "Submit an invoice" %>
                  <%= turbo_frame_tag dom_id(position, :invoice_form), src: new_payroll_position_invoice_path(position), loading: :lazy do %>
                    <%= render "application/loading_container", klass: "py-8" %>
                  <% end %>
                </section>
              <% elsif next_step %>
                <% case next_step[:key] %>
                <% when :tax_form %>
                  <%= link_to tax_forms_path(legal_entity_id: legal_entity&.hashid), class: "btn bg-warning nowrap" do %>
                    <%= inline_icon "docs" %>
                    Complete tax form
                  <% end %>
                <% when :payout_method %>
                  <%= link_to settings_payouts_path(legal_entity_id: legal_entity&.id), class: "btn bg-warning nowrap" do %>
                    <%= inline_icon "bank-account" %>
                    Configure payouts
                  <% end %>
                <% else %>
                  <span class="muted nowrap"><%= next_step[:label] %></span>
                <% end %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </article>

  <% if @invoices.any? %>
    <h2 class="mt-0 mb-2">Pending invoices</h2>
    <article class="table-container mb-4">
      <table>
        <thead>
          <tr>
            <th>Status</th>
            <th>Date</th>
            <th>Organization</th>
            <th>Description</th>
            <th class="text-right">Amount</th>
          </tr>
        </thead>
        <tbody>
          <% @invoices.each do |invoice| %>
            <% state_color = invoice.approved? ? "success" : (invoice.rejected? ? "muted" : "warning") %>
            <tr>
              <td><span class="badge ml-0 bg-<%= state_color %>"><%= invoice.aasm_state.humanize %></span></td>
              <td><%= format_date invoice.created_at %></td>
              <td><strong><%= invoice.event.name %></strong></td>
              <td style="max-width: 25ch;" class="overflow-hidden truncate" title="<%= invoice.name %>">
                <%= invoice.name %>
              </td>
              <td class="text-right"><%= render_money invoice.amount_cents %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </article>
  <% end %>

  <h2 class="mt-0 mb-2">Payment history</h2>
<% end %>

<div class="flex items-center gap-2 flex-col-reverse sm:flex-row mb-2">
  <%= form_with(model: false, local: true, method: :get, class: "flex-1 w-full sm:w-auto") do |form| %>
    <%= render "events/filters/search", form: %>
  <% end %>

  <%= render "events/filters/menu", filters: @filter_options unless @has_filter %>
</div>

<%= render "events/filters/bar", filters: @filter_options if @has_filter %>

<% if @payments.any? %>
  <article class="table-container">
    <table>
      <thead>
        <tr>
          <th>Status</th>
          <th>Date</th>
          <th>Event</th>
          <th>For</th>
          <th>Amount</th>
        </tr>
      </thead>
      <tbody>
        <% @payments.each do |payment| %>
          <% payout = payment.payout %>
          <% state_color = { "pending_legal_entity" => "muted", "under_review" => "info", "sent" => "info", "successful" => "success", "rejected" => "error" }[payment.aasm_state] %>
          <tr class="clickable">
            <td>
              <span class="ml0 badge bg-<%= state_color %>">
                <%= payment.aasm_state.humanize %>
              </span>
            </td>
            <td><%= format_date payment.created_at %></td>
            <td><%= payment.event.name %></td>
            <td style="max-width: 25ch;">
              <div class="overflow-hidden truncate" title="<%= payment.purpose %>"><%= payment.purpose %></div>
              <% invoice_receipt = payment.payroll_invoice&.receipts&.first %>
              <% if invoice_receipt&.file&.attached? %>
                <%= link_to "View invoice", url_for(invoice_receipt.file), class: "muted text-xs relative z-10", data: { turbo_frame: "_top" } %>
              <% end %>
            </td>
            <td>
              <%= render_money payment.amount_cents %>

              <% if payout.present? && policy(payout.local_hcb_code).show? %>
                <%= link_to "", hcb_code_url(payout.hcb_code), class: "stretched-link", data: popovers_enabled? ? hcb_code_popover_data(payout.local_hcb_code) : nil %>
              <% else %>
                <%= link_to "", payment_path(payment), class: "stretched-link", data: popovers_enabled? ? payment_popover_data(payment) : nil %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </article>

  <%= paginate @payments %>
<% else %>
  <p class="muted">No payments yet.</p>
<% end %>
