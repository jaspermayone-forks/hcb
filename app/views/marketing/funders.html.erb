      <li><%= image_tag "https://cdn.hackclub.com/019edcbb-46d2-74bd-93d3-63bf843af555/image.png", alt: "Alfred P. Sloan Foundation", loading: "lazy", decoding: "async" %></li>
      <li><%= image_tag "https://cdn.hackclub.com/019edcbd-7b5b-7ebf-9086-a4839acf0933/logo_svg.svg", alt: "SoftBank", loading: "lazy", decoding: "async" %></li>
      <li><%= image_tag "https://cdn.hackclub.com/019edcbb-71d3-755b-bf22-b4e958e3b0e9/founders_fund_logo__2015_.svg", alt: "Founders Fund", loading: "lazy", decoding: "async" %></li>
      <li><%= image_tag "https://cdn.hackclub.com/019edcbb-40c8-7556-a50b-2148294561a0/image.png", alt: "11th Hour Project, The Schmidt Family Foundation", loading: "lazy", decoding: "async" %></li>
      <li><%= image_tag "https://cdn.hackclub.com/019edcbd-7e32-7078-a5b8-bdc47102cf96/protocol-labs-logo-black.svg", alt: "Protocol Labs", loading: "lazy", decoding: "async" %></li>
      <li><%= image_tag "https://cdn.hackclub.com/019edcca-3c1d-7a8a-8579-a900076d05c5/rbf_2019logo_full-color_no-tagline.png", alt: "Rockefeller Brothers Fund", loading: "lazy", decoding: "async" %></li>
      <li><%= image_tag "https://cdn.hackclub.com/019edcbb-5648-772a-a368-be9751e81f62/image.png", alt: "EQT Foundation", loading: "lazy", decoding: "async" %></li>
      <li><%= image_tag "https://cdn.hackclub.com/019edcbb-540c-71fa-819f-08c17ae34297/future_of_life_institute_logo.svg", alt: "Future of Life Institute", loading: "lazy", decoding: "async" %></li>
      <li><%= image_tag "https://cdn.hackclub.com/019edcfa-9eea-7015-b7ab-170d560ca012/founders_pledge_green.svg", alt: "Founders Pledge", loading: "lazy", decoding: "async" %></li>
    </ul>
  </div>
</section>

<%# ============================ CASE STUDIES / TESTIMONIALS ============================ %>
<%# "Funders on HCB" — currently a single testimonial: the Ghostty/Mitchell quote (pending
    his sign-off). Gated behind :funders_landing_testimonials (the section's rollout flag). %>
<% if @show_testimonials %>
  <section class="mk-section mk-section--alt">
    <div class="mk-container">
      <div class="mk-section__head">
        <p class="mk-eyebrow">Funders on HCB</p>
        <h2 class="mk-section__title">Trusted to move capital that matters.</h2>
      </div>
      <div class="mk-cases">
        <%# TODO(content): quote adapted from Mitchell Hashimoto's published writing
            (mitchellh.com/writing/ghostty-non-profit + ghostty.org/docs/sponsor) — pending
            his approval. %>
        <figure class="mk-case">
          <blockquote>“With HCB, we could start accepting tax-deductible donations and operate
            under a charitable structure on a much faster timeline. They do amazing work. I
            would’ve supported them regardless.”</blockquote>
          <figcaption>
            <%= image_tag "https://cdn.hackclub.com/019e8635-0733-77b6-9442-bfe6a1b7b3a8/image.png",
                          class: "mk-case__avatar", alt: "", width: 84, height: 84,
                          loading: "lazy", decoding: "async" %>
            <span class="mk-case__meta">
              <span class="mk-case__name">Mitchell Hashimoto</span>
              <span class="mk-case__detail">Creator of Ghostty · co-founder of HashiCorp</span>
            </span>
          </figcaption>
        </figure>
      </div>
    </div>
  </section>
<% end %>

<%# ============================ TRUST ============================ %>
<section class="mk-section">
  <div class="mk-container mk-narrow mk-trust">
    <p class="mk-eyebrow">Built to be trusted</p>
    <h2 class="mk-section__title">Serious infrastructure for serious capital.</h2>
    <p class="mk-lead">
      HCB is operated by The Hack Foundation (Hack Club), a registered 501(c)(3) nonprofit.
      Since 2018 we've run the financial back office for thousands of organizations. It's the
      same infrastructure, proven at that scale, now open to funders. Funds are
      held and moved through established partners, <strong>Column N.A. (Member FDIC)</strong>
      and <strong>Stripe</strong>. Transparency is optional: publish your giving or keep it
      private, including anonymously.
    </p>
    <ul class="mk-badges">
      <li>501(c)(3) nonprofit</li>
      <li>Public or private giving</li>
      <li><a href="https://github.com/hackclub/hcb">Open source</a></li>
    </ul>
  </div>
</section>

<%# ============================ FINAL CTA ============================ %>
<section class="mk-section mk-cta" id="talk-to-us">
  <div class="mk-container mk-narrow mk-cta__inner">
    <% if flash[:funder_inquiry] == "received" %>
      <div class="mk-notice mk-notice--success" role="status">
        <span class="mk-notice__icon"><%= inline_icon "check-circle-fill", size: 24 %></span>
        <div>
          <strong>Thanks, we've got your note.</strong>
          Someone from our team will be in touch within one business day, and we've emailed
          you a copy.
        </div>
      </div>
    <% else %>
      <h2 class="mk-cta__title">Put your capital to work.</h2>
      <p class="mk-lead">HCB pairs modern financial software with a hands-on team. You get a
        partner who helps map your giving and runs the operations behind it, not just a login.
        Tell us what you want to fund.</p>
      <% if flash[:error].present? %>
        <div class="mk-notice mk-notice--error" role="alert">
          <span class="mk-notice__icon"><%= inline_icon "important-fill", size: 24 %></span>
          <div><%= flash[:error] %></div>
        </div>
      <% end %>
      <div class="mk-cta__form">
        <%= render "marketing/funder_inquiry_form", detailed: true %>
      </div>

      <div class="mk-next">
        <ol class="mk-next__steps">
          <li><span class="mk-next__num">1</span>Send us a note about what you want to fund.</li>
          <li><span class="mk-next__num">2</span>A real person replies, usually to set up a short call.</li>
          <li><span class="mk-next__num">3</span>We map out your giving together. You decide, with no commitment.</li>
        </ol>
        <div class="mk-team">
          <p class="mk-team__label">You'll hear from one of us</p>
          <ul class="mk-team__list">
            <li>
              <img class="mk-team__avatar" src="https://cdn.hackclub.com/019e7570-8304-7de8-abfe-cbcaf12616b7/image.png" alt="" width="72" height="72" loading="lazy" decoding="async">
              Melanie Smith
            </li>
            <li>
              <img class="mk-team__avatar" src="https://cdn.hackclub.com/019e7570-80b5-7eae-9d54-cf4bf1460953/image.png" alt="" width="72" height="72" loading="lazy" decoding="async">
              Paul Spitler
            </li>
            <li>
              <img class="mk-team__avatar" src="https://cdn.hackclub.com/019e7570-7d87-707e-bb85-4d39a3fc5114/image.png" alt="" width="72" height="72" loading="lazy" decoding="async">
              Gary Tou
            </li>
          </ul>
        </div>
      </div>
    <% end %>
    <p class="mk-cta__brandline">HCB. The modern infrastructure for funding the future.</p>
  </div>
</section>
