<% title "HCB Fees" %>

<%= form_with local: true, class: "card overflow-visible", url: bank_fees_admin_index_path, method: :get do |form| %>
  <div class="flex flex-col sm:flex-row items-center gap-2">
    <%= combobox_tag :event_id, event_search_admin_index_path, placeholder: "Event", class: "!max-w-full !min-w-full sm:!min-w-72", value: @event&.to_combobox_display %>
  </div>
  <div class="flex items-center mt-2">
    <%= form.submit "Search", class: "ml-auto" %>
  </div>
<% end %>

<div class="flex items-center mb2 flex-col sm:flex-row">
  <div class="flex-grow">
    <%= page_entries_info @bank_fees, entry_name: "HCB fees" %>
    (<%= render_money @sum %>)
  </div>
  <%= paginate @bank_fees %>
</div>

<table>
  <thead>
    <tr>
      <th>ID</th>
      <th>Date</th>
      <th>Status</th>
      <th>HCB Code</th>
      <th>Memo</th>
      <th>Amount</th>
      <th>Event</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @bank_fees.each do |bank_fee| %>
      <tr style="
      ">
        <td><%= bank_fee.id %></td>
        <td><%= bank_fee.created_at.strftime("%Y-%m-%d") %></td>
        <td><%= bank_fee.aasm_state %></td>
        <td><%= bank_fee.hcb_code %></td>
        <td></td>
        <td><%= bank_fee.amount %></td>
        <td><%= bank_fee.event_id %></td>
        <td>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= paginate @bank_fees %>
