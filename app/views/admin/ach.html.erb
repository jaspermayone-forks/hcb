<% title "ACH Transfers" %>

<%= form_with local: true, class: "card overflow-visible", url: ach_admin_index_path, method: :get do |form| %>
  <div class="flex flex-col sm:flex-row items-center gap-2">
    <%= render "events/filters/search", form: %>
    <%= combobox_tag :event_id, event_search_admin_index_path, placeholder: "Event", class: "!max-w-full !min-w-full sm:!min-w-72", value: @event&.to_combobox_display %>
  </div>
  <div class="flex items-center mt-2 gap-4 flex-wrap">
    <%= form.label :pending do %>
      <%= form.check_box :pending, checked: @pending %> Pending
    <% end %>
    <%= form.submit "Search", class: "ml-auto" %>
  </div>
<% end %>

<div class="flex items-center mb2 flex-col sm:flex-row">
  <div class="flex-grow">
    <%= page_entries_info @ach_transfers, entry_name: "ACH transfers" %>
  </div>
  <%= paginate @ach_transfers %>
</div>

<table>
  <thead>
    <tr>
      <th>ID</th>
      <th>Date</th>
      <th>Recipient</th>
      <th>Amount</th>
      <th>Status</th>
      <th>Confirmation No.</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @ach_transfers.each do |ach| %>
      <tr class="<%= "admin-bg-pending" if ach.pending? %> <%= "admin-bg-transit" if ach.in_transit? %>">
        <td><%= ach.id %></td>
        <td><%= ach.created_at.strftime("%Y-%m-%d") %></td>
        <td>
          <%= link_to ach_transfer_path(ach) do %>
            <%= ach.event.name.upcase %>: <%= ach.recipient_name.upcase %>
          <% end %>
        </td>
        <td><%= render_money_amount(ach.amount) %></td>
        <td>
          <%= ach.aasm_state.upcase %>
          <% if ach.pending_expired? %>
            <span>⚠️ (Overdue)</span>
          <% end %>
        </td>
        <td><%= ach.confirmation_number %></td>
        <td>
          <%= link_to "Process", ach_start_approval_admin_path(ach) if ach.pending? %>
          <%= link_to "View", ach_start_approval_admin_path(ach) unless ach.pending? %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= paginate @ach_transfers %>
