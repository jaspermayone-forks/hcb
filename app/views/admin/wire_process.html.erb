<div class="flex flex-row items-center justify-start gap-4">
  <%= link_to wires_admin_index_path, class: "btn btn-small bg-muted" do %>
    <%= inline_icon "view-back" %>
    Back to wires
  <% end %>

  <%= link_to hcb_code_path(@wire.hcb_code), class: "btn btn-small bg-muted flex-shrink-0", target: "_blank" do %>
    <%= inline_icon "payment-transfer" %>
    View transaction (<%= pluralize(@wire.local_hcb_code.comments.count, "comment") %>)
  <% end %>

  <div class="flex-grow"></div>

  <% if @wire.column_id.present? %>
    <%= link_to("https://dashboard.column.com/app/transfers/edit/intl-wire/#{@wire.column_id}", class: "btn btn-small bg-none !bg-[#4575CD] hover:saturate-[125%] transition-all !text-white flex-shrink-0", target: "_blank") do %>
      <%= inline_icon "column" %>
      Open Column (<%= @wire.column_id %>)
    <% end %>
  <% end %>
</div>

<h1>Process Wire #<%= @wire.id %></h1>
<p><small>Current Status: <%= @wire.aasm_state %></small></p>

<hr>

<div class="grid grid-cols-1 lg:grid-cols-2">
  <div>
    <h3>Transfer Details</h3>

    <table class="table--autosize">
      <tbody>
        <tr>
          <td>Event:</td>
          <td>
            <%= @wire.event.name %>
            <%= "(❄️ ⚠️ CURRENTLY FINANCIALLY FROZEN)" if @wire.event.financially_frozen? %>
          </td>
        </tr>
        <tr>
          <td>Requested at:</td>
          <td><%= format_datetime @wire.created_at %></td>
        </tr>
        <tr>
          <td>Sent To:</td>
          <td><%= @wire.recipient_name %></td>
        </tr>
        <tr>
          <td>Email:</td>
          <td><%= @wire.recipient_email %></td>
        </tr>
        <tr>
          <td>BIC / Swift Code:</td>
          <td><%= @wire.bic_code %></td>
        </tr>
        <tr>
          <td>Account number:</td>
          <td><%= @wire.account_number %></td>
        </tr>
        <tr>
          <td>Memo:</td>
          <td><%= @wire.memo %></td>
        </tr>
        <tr>
          <td>Payment Purpose:</td>
          <td><%= @wire.payment_for %></td>
        </tr>
        <tr>
          <td>Currency:</td>
          <td><%= @wire.currency %></td>
        </tr>
        <tr>
          <td>Address (Line 1):</td>
          <td><%= @wire.address_line1 %></td>
        </tr>
        <tr>
          <td>Address (Line 2):</td>
          <td><%= @wire.address_line2 %></td>
        </tr>
        <tr>
          <td>City:</td>
          <td><%= @wire.address_city %></td>
        </tr>
        <tr>
          <td>State:</td>
          <td><%= @wire.address_state %></td>
        </tr>
        <tr>
          <td>Postal code:</td>
          <td><%= @wire.address_postal_code %></td>
        </tr>
        <tr>
          <td>Recipient country:</td>
          <td><%= @wire.recipient_country %></td>
        </tr>
        <tr>
          <td>Amount (local currency):</td>
          <td><%= Money.from_cents(@wire.amount_cents, @wire.currency).format %></td>
        </tr>
        <tr>
          <td>Balance available:</td>
          <td>
            <%= render_money @wire.event.balance_available_v2_cents %>
            <% if @wire.event.balance_available_v2_cents < 0 %>
              <span class="ml1 badge bg-error">⚠️ Negative balance</span>
            <% end %>
          </td>
        </tr>
        <% @wire.recipient_information&.keys&.each do |key| %>
          <% if @wire.recipient_information[key].presence != nil %>
            <tr>
              <td><%= key.humanize %></td>
              <td><%= @wire.recipient_information[key] %></td>
            </tr>
          <% end %>
        <% end %>
        <tr>
          <td colspan="2">
            <%= button_to "✏️ Edit wire", edit_wire_path(@wire), method: :get %>
          </td>
        </tr>
      </tbody>
    </table>

    <%= render partial: "receipts/receipt", collection: @wire.local_hcb_code.receipts.order(created_at: :asc), as: :receipt, locals: { link_to_file: true } %>
  </div>

  <div>
    <h3>Process</h3>

    <% if @wire.pending? %>
      <fieldset class="p-4">
        <legend class="py-0 px-2">Send</legend>

        <div class="field mb-3">
          <label class="bold mb1">Transaction category</label>
          <br>
          <%= render(
                partial: "hcb_codes/transaction_category_form",
                locals: { model: @wire.local_hcb_code.ct || @wire.local_hcb_code.pt }
              ) %>
        </div>

        <%= form_with(model: false, local: true, url: send_wire_path(@wire), method: :post, class: "mb-0") do |form| %>
          <div class="field mb-2">
            <%= form.check_box :charge_fee %>
            <%= form.label :charge_fee, "Charge #{@wire.event.name} $25 to cover transfer fee?", class: "bold ml-2" %>
          </div>
          <%= form.submit "💸 Approve and automatically send transfer", data: { confirm: "This will automatically send the wire. You don't need to send it manually!" }, class: "mb-0" %>
        <% end %>
        <hr>
        <%= button_to "🔧 Approve and manually send transfer", approve_wire_path(@wire), method: :post, data: { confirm: "Have you manually sent this wire? This option requires you send this wire." } %>
      </fieldset>

      <fieldset class="px-6 py-3">
        <legend class="py-0 px-2">Reject</legend>

        <%= form_with(model: false, local: true, url: reject_wire_path(@wire), method: :post) do |form| %>
          <small class="mb-5 mt-0 block">This requires you to communicate to the organizer about the reason why.</small>
          <div class="field">
            <%= form.label "Reject with a comment", class: "bold mb1" %> <br>
            <%= form.text_area :comment, style: "width: 400px;", placeholder: "(Markdown supported)" %>
          </div>
          <%= form.submit "Reject", data: { confirm: "Mark as rejected? This requires you to communicate to the organizer about the reason why." } %>
        <% end %>
      </fieldset>
    <% else %>
      <p>This wire <%= @wire.failed? ? "" : "is " %><b><%= @wire.aasm.current_state.to_s.humanize(capitalize: false) %></b><%= @wire.failed? ? @wire.return_reason.present? ? " with the following failure reason: #{@wire.return_reason}" : " for an unknown reason" : "" %>.</p>
      <% unless @wire.failed? %>
        <%= button_to "Reject as failed", reject_wire_path(@wire) %>
      <% end %>
    <% end %>
  </div>
</div>
