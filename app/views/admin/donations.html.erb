<% title "Donations" %>

<%= form_with local: true, class: "card overflow-visible", url: donations_admin_index_path, method: :get do |form| %>
  <div class="flex flex-col sm:flex-row items-center gap-2">
    <%= render "events/filters/search", form: %>
    <%= form.text_field :ip_address, value: params[:ip_address], placeholder: "IP Address" %>
    <%= form.text_field :user_agent, value: params[:user_agent], placeholder: "User Agent" %>
    <%= combobox_tag :event_id, event_search_admin_index_path, placeholder: "Event", class: "!max-w-full !min-w-full sm:!min-w-72", value: @event&.to_combobox_display %>
  </div>
  <div class="flex items-center mt-2 gap-4 flex-wrap">
    <%= form.label :deposited do %>
      <%= form.check_box :deposited, checked: @deposited %> Deposited
    <% end %>
    <%= form.label :in_transit do %>
      <%= form.check_box :in_transit, checked: @in_transit %> In Transit
    <% end %>
    <%= form.label :failed do %>
      <%= form.check_box :failed, checked: @failed %> Failed
    <% end %>
    <%= form.label :missing_payout do %>
      <%= form.check_box :missing_payout, checked: @missing_payout %> Missing Payout
    <% end %>
    <%= form.label :missing_fee_reimbursement do %>
      <%= form.check_box :missing_fee_reimbursement, checked: @missing_fee_reimbursement %> Missing FeeReimbursement
    <% end %>
    <%= form.submit "Search", class: "ml-auto" %>
  </div>
<% end %>

<div class="flex items-center mb2 flex-col sm:flex-row">
  <div class="flex-grow">
    <%= page_entries_info @donations, entry_name: "donations" %>
  </div>
  <%= paginate @donations %>
</div>

<table>
  <thead>
    <tr>
      <th>ID</th>
      <th>Date</th>
      <th>Recipient</th>
      <th>Anonymous</th>
      <th>Tax-Deductible</th>
      <th>Amount</th>
      <th>Status</th>
      <th>PayoutId</th>
      <th>FeeReimbursementId</th>
      <th>IP Address</th>
      <th>User Agent</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @donations.each do |donation| %>
      <tr class="<%= "admin-bg-transit" if donation.in_transit? %>">
        <td><%= donation.id %></td>
        <td>
          <%= donation.created_at.strftime("%Y-%m-%d") %>
          <% if donation.pending_expired? %>
            <span>⚠️ (Overdue)</span>
          <% end %>
        </td>
        <td>
          <%= link_to donation_path(donation) do %>
            <%= donation.event.name.upcase %>: <%= donation.name(show_anonymous: true) %>
          <% end %>
        </td>
        <td><%= donation.anonymous? %></td>
        <td><%= donation.tax_deductible? %></td>
        <td><%= render_money_amount(donation.amount) %></td>
        <td><%= donation.aasm_state.upcase %></td>
        <td><%= donation.payout_id %></td>
        <td><%= donation.fee_reimbursement_id %></td>
        <td><%= donation.ip_address %></td>
        <td><%= donation.user_agent %></td>
        <td>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= paginate @donations %>
