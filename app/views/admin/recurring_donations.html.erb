<% title "Recurring Donations" %>

<%= form_with local: true, class: "card overflow-visible", url: recurring_donations_admin_index_path, method: :get do |form| %>
  <%= combobox_tag :event_id, event_search_admin_index_path, placeholder: "Event", class: "!max-w-full !min-w-full sm:!min-w-72", value: @event&.to_combobox_display %>
  <div class="flex items-center mt-2 gap-4 flex-wrap">
    <%= form.label :active do %>
      <%= form.check_box :active, checked: @active %> Active
    <% end %>
    <%= form.label :canceled do %>
      <%= form.check_box :canceled, checked: @canceled %> Canceled
    <% end %>
    <%= form.submit "Search", class: "ml-auto" %>
  </div>
<% end %>

<div class="flex items-center mb2 flex-col sm:flex-row">
  <div class="flex-grow">
    <%= page_entries_info @donations, entry_name: "donations" %>
  </div>
  <%= paginate @donations %>
</div>

<table>
  <thead>
    <tr>
      <th>ID</th>
      <th>Date</th>
      <th>Donor</th>
      <th>Anonymous</th>
      <th>Tax-Deductible</th>
      <th>Amount</th>
      <th>Status</th>
      <th>Cancel</th>
    </tr>
  </thead>
  <tbody>
    <% @donations.each do |donation| %>
      <tr class="<%= "admin-bg-transit" if donation.active? %>">
        <td><%= donation.id %></td>
        <td><%= donation.created_at.strftime("%Y-%m-%d") %></td>
        <td>
          <%= link_to recurring_donation_path(donation.url_hash) do %>
            <%= donation.event.name.upcase %>: <%= donation.name(show_anonymous: true) %>
          <% end %>
        </td>
        <td><%= donation.anonymous? %></td>
        <td><%= donation.tax_deductible? %></td>
        <td><strong><%= render_money(donation.amount) %></strong>/month</td>
        <td><%= donation.stripe_status.humanize %></td>
        <td><%= link_to "Cancel donation", cancel_recurring_donation_path(donation.url_hash), method: :post, data: { confirm: "Are you sure you'd like to cancel this donation to #{donation.event.name}?" } if !donation.canceled? %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= paginate @donations %>
