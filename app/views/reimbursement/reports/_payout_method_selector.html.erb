<%# locals: (report:) %>

<% legal_entity = report.user.personal_legal_entity %>
<% methods = legal_entity ? legal_entity.payout_methods.unarchived.includes(:details).order(created_at: :asc) : [] %>
<% current = report.legal_entity_payout_method %>

<div class="card mt-4 flex items-center justify-between" style="gap: 1rem;">
  <div style="min-width: 0;">
    <h3 class="mt-0 mb-1">Payout method</h3>
    <p class="muted mt-0 mb-0" style="font-size: 13px;">
        Choose which of your payout methods this report will be reimbursed to. You can only change this
        while the report is a draft. Picking a method in another currency will convert your expense amounts.
    </p>
  </div>

  <div data-controller="menu" data-menu-placement-value="bottom-end" class="flex-shrink-0">
    <button type="button" class="btn bg-snow flex items-center text-left" style="gap: 8px;width:16rem"
            data-menu-target="toggle"
            data-action="menu#toggle click@document->menu#close keydown@document->menu#keydown">
      <span class="flex-1 truncate"><%= current ? current.short_label : "Choose…" %></span>
      <%= inline_icon "down-caret", size: 20 %>
    </button>

    <div class="menu__content menu__content--2 h5 menu__content--compact" data-menu-target="content">
      <% methods.each do |pm| %>
        <%= link_to reimbursement_report_update_payout_method_path(report, legal_entity_payout_method_id: pm.id),
              class: "flex items-center#{" bold" if pm == current}", data: { turbo_method: :post } do %>
          <%= inline_icon pm.icon, size: 24 %>
          <%= pm.short_label %>
        <% end %>
      <% end %>

      <div class="menu__divider"></div>
      <%= link_to settings_payouts_path(legal_entity_id: legal_entity&.id), class: "flex items-center" do %>
        <%= inline_icon "settings", size: 24 %>
        Manage payout methods
      <% end %>
    </div>
  </div>
</div>
