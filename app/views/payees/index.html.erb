<% destination = params[:destination].presence || "payments" %>

<%= turbo_frame_tag :payee_results do %>
  <%= form_with(url: event_payees_path(event_id: @event.slug), method: :get, class: "px-4 pb-2 pt-1", data: { turbo_frame: "payee_results_list", controller: "form" }) do |form| %>
    <%= hidden_field_tag :destination, destination %>
    <%= form.hidden_field :payee_id, value: params[:payee_id] %>
    <div class="input input-group max-w-none mt-1">
      <%= inline_icon "search" %>
      <%= form.text_field :q, value: params[:q], placeholder: "Search...", autofocus: true, class: "bg-transparent", autocomplete: "off", data: { action: "input->form#submitDebounced input->payee-picker#search" } %>
    </div>
  <% end %>

  <%= turbo_frame_tag :payee_results_list do %>
    <% if @payees.any? %>
      <% @payees.each do |payee| %>
        <div class="btn btn--list-item border-t rounded-none relative">
          <%= link_to "", new_recipient_transfer_path(destination, @event, payee_id: payee.hashid), class: "absolute inset-0", data: { turbo_frame: "_top" }, "aria-label": "Select #{payee.display_name}" %>
          <%= avatar_for_email payee.email, size: 40, class: "rounded-full w-10 h-10 shrink-0" %>
          <div class="flex-1 min-w-0">
            <p class="font-medium truncate"><%= payee.display_name %></p>
            <% legal_name = payee.legal_entity&.name.presence %>
            <% legal_name = nil if legal_name == payee.display_name %>
            <p class="text-sm muted truncate"><%= "#{legal_name} • " if legal_name %><%= payee.email %></p>
          </div>
          <% if payee.managed? %>
            <span class="badge bg-muted shrink-0">Managed</span>
          <% end %>
          <% if params[:payee_id].to_s == payee.hashid %>
            <%= inline_icon "check-thin", class: "success shrink-0" %>
          <% end %>

          <% if policy(payee).update? || policy(payee).archive? %>
            <div data-controller="menu" data-menu-placement-value="bottom-end" class="shrink-0 relative" style="z-index: 1">
              <%= pop_icon_to "more", "#",
                    class: "align-middle muted", "aria-label": "Recipient options",
                    data: { turbo: false, "menu-target": "toggle", action: "menu#toggle click@document->menu#close keydown@document->menu#keydown" } %>
              <div class="menu__content menu__content--2 h5 menu__content--compact" data-menu-target="content">
                <% if policy(payee).update? %>
                  <%= link_to new_event_payment_path(event_id: @event.slug, payee_id: payee.hashid, edit_payee: true), class: "flex items-center", data: { turbo_frame: "_top" } do %>
                    <%= inline_icon "edit", size: 24 %>
                    Edit recipient
                  <% end %>
                <% end %>
                <% if policy(payee).archive? %>
                  <%= link_to archive_event_payee_path(event_id: @event.slug, id: payee.hashid), class: "flex items-center", data: { turbo_method: :post, turbo_frame: "_top", turbo_confirm: "Archive #{payee.display_name}? They'll be hidden from the recipient list." } do %>
                    <%= inline_icon "delete", size: 24 %>
                    Archive recipient
                  <% end %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    <% elsif params[:q].present? %>
      <div class="px-4">
        <%= blankslate "No results for \"#{params[:q]}\"", class: "py-5 text-sm mb-2" %>
      </div>
    <% end %>
  <% end %>
<% end %>
