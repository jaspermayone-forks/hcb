<% unless stripe_card.canceled? || !policy(stripe_card).cancel? %>
  <div class="tooltipped tooltipped--n">
    <%= link_to cancel_stripe_card_path(stripe_card),
                class: "btn bg-error btn--list-item",
                data: { turbo_method: :post, turbo_confirm: "Are you sure you want to do this? Unlike freezing a card, this can't be reversed.", turbo_confirm_danger: true } do %>
      <%= inline_icon "flame" %>
      <div>
        <p><strong>Burn</strong></p>
        <p class="text-sm opacity-60">Permanently cancel this card</p>
      </div>
    <% end %>
  </div>
<% end %>
