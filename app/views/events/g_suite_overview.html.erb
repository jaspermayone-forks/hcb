<% title "Google Workspace for #{@event.name}" %>
<% page_md %>
<%= render "events/nav", selected: :google_workspace %>
<% if !@event.g_suites.exists? && !Flipper.enabled?(:google_workspace, @event) %>
  <%= render "events/one_pager",
     title: "Google Workspace",
     screenshots: {
       light: "https://cdn.hackclub.com/rescue?url=https://hc-cdn.hel1.your-objectstorage.com/s/v3/38684750e541e695_image.png",
       dark: "https://cdn.hackclub.com/rescue?url=https://hc-cdn.hel1.your-objectstorage.com/s/v3/38684750e541e695_image.png"
     },
     hints: [
       {
         icon: "docs",
         title: "Get access to the full Google Workspace suite",
         description: "You'll be able to use Google Docs, Sheets, Slides, and more!"
       },
       {
         icon: "email",
         title: "Create email aliases",
         description: "Create multiple email aliases for your organization, such as hey@yourdomain.com"
       }
     ] do %>
       <%= link_to (@waitlist_form_submitted ? "You're on the waitlist!" : "Join the waitlist"),
       (@waitlist_form_submitted ? "#" : fillout_form("52bVNmqdeQus", { "OrgName" => @event.name, "OrgURL" => event_url(@event), "UserEmail" => current_user.email, "OrgID" => @event.id, "OrgBal" => @event.balance_available_v2_cents / 100 })),
       class: "btn mt-2 #{'disabled' if @waitlist_form_submitted || !policy(@event).g_suite_create?}",
       tooltip: (@waitlist_form_submitted ? "You're already on the waitlist." : !policy(@event).g_suite_create? ? "Only managers can sign up for this." : "Join the waitlist.") %>
       <p class="muted text-sm flex items-center">
         <%= inline_icon "info", size: 20, class: "mr-2" %>
         Due to limited space, we're currently operating a waitlist.
       </p>
 <% end %>
<% else %>
  <h1 class="heading">
    <span class="flex-auto pr2">
      Google Workspace
    </span>
    <% if @g_suite %>
      <% admin_tool("mr1 p1 badge", "span") do %>
        <%= link_to "Process", google_workspace_process_admin_path(@g_suite) %>
      <% end %>
    <% end %>
    <%= content_tag :span, @g_suite.domain, class: "badge bg-info h3 ml0" if @g_suite %>
  </h1>
  <%= render partial: "application/admin_viewer", locals: { record: @g_suite } %>
  <div class="mb-2"></div>
  <% if @g_suite.present? %>
    <% if @g_suite.revocation.present? %>
      <%= render "g_suite_revocations/notice" %>
    <% end %>
    <% if @g_suite.verification_error? && @g_suite.previously_verified? && !(@g_suite.revocation.present? && @g_suite.revocation.revoked?) %>
      <%= render "application/callout", type: "error", title: "We've detected that you're missing some DNS records required by Google Workspace." do %>
        You can still access, configure, and manage accounts, but you may be unable to send or receive emails until after you've fixed <%= @g_suite.domain %>'s DNS records.
      <% end %>
    <% end %>
    <% if !@g_suite.revocation&.revoked? %>
      <%= render "g_suites/panel" %>
    <% end %>
  <% else %>
    <%= render "g_suites/form" %>
  <% end %>
<% end %>
