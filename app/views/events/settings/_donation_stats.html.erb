<%# locals: (event:, frame:, disabled:) %>
<% if frame %>
  <div class="menu__divider m-0 my-8"></div>
<% end %>
<div class="field field--checkbox mb0 card mt-4">
  <div>
    <span style="font-weight: 700">Show top donors</span>
    <p class="text-muted mt-0.5 mb-0 text-sm">
      Display a leaderboard of top non-anonymous donors by total amount contributed.
    </p>
  </div>
  <div class="field--checkbox--switch ml-auto" style="flex-shrink:0">
    <%= form_with(model: event, local: true) do |form| %>
      <%= form.hidden_field :tab, value: "donations" %>
      <%= form.label :show_top_donors do %>
        <%= form.check_box :show_top_donors,
          data: { action: "change->accordion#toggle", target: "accordion.checkbox" },
          disabled:,
          checked: event.show_top_donors,
          onchange: "this.closest('form').requestSubmit();",
          switch: true %>
        <span class="slider"></span>
      <% end %>
    <% end %>
  </div>
</div>

<div class="field field--checkbox mb0 card mt-4">
  <div>
    <span style="font-weight: 700">Show recent donors</span>
    <p class="text-muted mt-0.5 mb-0 text-sm">
      Display the most recent donations. The names of anonymous donors are hidden.
    </p>
  </div>
  <div class="field--checkbox--switch ml-auto" style="flex-shrink:0">
    <%= form_with(model: event, local: true) do |form| %>
      <%= form.hidden_field :tab, value: "donations" %>
      <%= form.label :show_recent_donors do %>
        <%= form.check_box :show_recent_donors,
          data: { action: "change->accordion#toggle", target: "accordion.checkbox" },
          disabled:,
          checked: event.show_recent_donors,
          onchange: "this.closest('form').requestSubmit();",
          switch: true %>
        <span class="slider"></span>
      <% end %>
    <% end %>
  </div>
</div>
