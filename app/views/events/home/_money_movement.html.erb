<%= turbo_frame_tag "money_movement" do %>
  <% unless @money_in.empty? && @money_out.empty? %>
    <div class="card card--breakdown shadow-none p-0 pb-4 px-0 flex-1 flex flex-col">
      <div class="p-2 pl-0 pt-4 sm:p-4 flex items-center justify-between">
        <h3 class="m-0">Money in</h3>
        <%= link_to event_transactions_path(@event, direction: "revenue"), class: "flex items-center shrink-0 no-underline" do %>
          See all
          <%= inline_icon "view-forward" %>
        <% end %>
      </div>

      <% if @money_in.empty? %>
        <div class="text-gray-500 bg-zinc-100 dark:bg-zinc-700 rounded-xl mx-4 flex-1 flex items-center text-center justify-center">
          You haven't received any money yet.
        </div>
      <% end %>

      <% @money_in.each do |transaction| %>
        <% rendered_transaction = capture do %>
          <div style="min-width:0;flex:1">
            <span class="truncate block"><%= transaction_memo(transaction) %></span>
            <div class="text-sm text-gray-500">
              <% if transaction.is_a?(CanonicalPendingTransaction) %>
                Pending &bull;
              <% end %>
              <% subtitle = transaction.date > 24.hours.ago ? "Earlier today" : "#{time_ago_in_words(transaction.date)} ago" %>
              <% if transaction.try(:raw_stripe_transaction) || transaction.try(:raw_pending_stripe_transaction_id) %>
                <% subtitle += ", #{transaction.stripe_cardholder.user.name}" %>
              <% end %>
              <%= subtitle %>
            </div>
          </div>
          <span class="text-xs font-bold p-1 <%= transaction.amount_cents > 0 ? "success" : "error" %>"><%= render_transaction_amount transaction.amount_cents %></span>
        <% end %>

        <% if organizer_signed_in? %>
          <% popover_enabled = popovers_enabled? && (@event || transaction.local_hcb_code.event).present? %>
          <% data_attributes = popover_enabled ? hcb_code_popover_data(transaction.local_hcb_code, event: @event) : {} %>
          <%= link_to url_for(transaction.local_hcb_code),
                class: "homepage-transaction #{"clickable" if popover_enabled}",
                data: data_attributes do %>
            <%= rendered_transaction %>
          <% end %>
        <% else %>
          <div class="homepage-transaction cursor-[unset]">
            <%= rendered_transaction %>
          </div>
        <% end %>
      <% end %>
    </div>

    <div class="card card--breakdown shadow-none p-0 pb-4 px-0 flex-1 flex flex-col">
      <div class="p-2 pl-0 pt-4 sm:p-4 flex items-center justify-between">
        <h3 class="m-0">Money out</h3>
        <%= link_to event_transactions_path(@event, direction: "expenses"), class: "flex items-center shrink-0 no-underline" do %>
          See all
          <%= inline_icon "view-forward" %>
        <% end %>
      </div>
      <% if @money_out.empty? %>
        <div class="text-gray-500 bg-zinc-100 dark:bg-zinc-700 rounded-xl mx-4 flex-1 flex items-center text-center justify-center">
          You haven't spent any money yet.
        </div>
      <% end %>

      <% @money_out.each do |transaction| %>
        <% rendered_transaction = capture do %>
          <div style="min-width:0;flex:1">
            <span class="truncate block"><%= transaction_memo(transaction) %></span>
            <div class="text-sm text-gray-500">
              <% if transaction.is_a?(CanonicalPendingTransaction) %>
                Pending &bull;
              <% end %>
              <% subtitle = transaction.date > 24.hours.ago ? "Earlier today" : "#{time_ago_in_words(transaction.date)} ago" %>
              <% if transaction.try(:raw_stripe_transaction) || transaction.try(:raw_pending_stripe_transaction_id) %>
                <% subtitle += ", #{transaction.stripe_cardholder.user.name}" %>
              <% end %>
              <%= subtitle %>
            </div>
          </div>
          <span class="text-xs font-bold p-1 <%= transaction.amount_cents > 0 ? "success" : "error" %>"><%= render_transaction_amount transaction.amount_cents %></span>
        <% end %>

        <% if organizer_signed_in? %>
          <% popover_enabled = popovers_enabled? && (@event || transaction.local_hcb_code.event).present? %>
          <% link_options = { class: "homepage-transaction #{"clickable" if popover_enabled}" } %>
          <% link_options[:data] = hcb_code_popover_data(transaction.local_hcb_code, event: @event) if popover_enabled %>
          <%= link_to url_for(transaction.local_hcb_code), link_options do %>
            <%= rendered_transaction %>
          <% end %>
        <% else %>
          <div class="homepage-transaction cursor-[unset]">
            <%= rendered_transaction %>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>
<% end %>
