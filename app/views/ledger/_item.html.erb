<tr>
  <td><%= item.hashid %></td>
  <td><%= item.datetime.strftime("%b %e, %Y") %></td>
  <td><%= truncate(item.memo, length: 80) %></td>
  <td class="nowrap"><%= item.amount.format %></td>
  <td>
  <% admin_tool("", "td") do %>
    <%= item.short_code %>
  <% end %>
  <td>
    <%= link_to "View", defined?(route_to) && route_to == :hcb_code ? ledger_item_hcb_path(item) : ledger_item_path(item) %>
  </td>
</tr>
