<%# locals: (card_grant:) %>

<div class="statset mb-2 flex flex-col">
  <div class="stat">
    <span class="stat__label">Balance remaining</span>
    <span class="stat__value"><%= card_grant.balance.format(symbol: false) %></span>
  </div>
  <% if card_grant.stripe_card&.canceled? %>
    <i class="muted">
      Refunds received after cancelation will be sent to <%= card_grant.event.name %>.
      <% if card_grant.reimbursement_report.present? %>
        The funds will not automatically be contributed towards your reimbursement report cap.
      <% end %>
    </i>
  <% elsif card_grant.stripe_card&.frozen? %>
    <i class="muted">
      Refunds received while frozen will still process and be returned to the card.
    </i>
  <% end %>
</div>
